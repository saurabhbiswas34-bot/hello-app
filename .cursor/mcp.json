{
  "mcpServers": {
    "atlassian-jira": {
      "command": "node",
      "args": [
        "${workspaceFolder}/.cursor/jira-mcp-runtime/node_modules/mcp-atlassian/dist/index.js"
      ],
      "env": {
        "ATLASSIAN_BASE_URL": "https://saurabhbiswas34.atlassian.net",
        "ATLASSIAN_EMAIL": "${ATLASSIAN_EMAIL}",
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
